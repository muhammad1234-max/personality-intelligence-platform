# MongoDB Connection String (Required)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>
MONGODB_URI=

# Groq API Key for AI Guidance (Required)
# Get one at https://console.groq.com/
GROQ_API_KEY=

# Admin Dashboard Password Hash (Required)
# Generate via: echo -n "your_password" | sha256sum
ADMIN_PASSWORD_HASH=

# Allowed CORS Origins (Optional, defaults to localhost in dev)
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=
